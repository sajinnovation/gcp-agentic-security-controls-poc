# Copy to .env and fill in your values
GOOGLE_GENAI_USE_VERTEXAI=1
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Model Armor (Layer 2: reasoning-based runtime screening)
ENABLE_MODEL_ARMOR=1
MODEL_ARMOR_TEMPLATE_ID=security-poc-template
# Or set full resource name after template creation:
# TEMPLATE_NAME=projects/your-project/locations/us-central1/templates/security-poc-template

# Sensitive Data Protection (Layer 1: deterministic PII detection)
ENABLE_SENSITIVE_DATA_PROTECTION=1
USE_CLOUD_DLP=0

# Agent model
AGENT_MODEL=gemini-2.5-flash

# Cloud Trace / OpenTelemetry (set automatically on deploy)
# GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
# OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=EVENT_ONLY

# Platform controls (enabled at deploy/infra time)
ENABLE_AGENT_IDENTITY=0
ENABLE_AGENT_GATEWAY=0
ENABLE_THREAT_DETECTION=0
ENABLE_SECOPS_AGENTS=0
ENABLE_CONFIDENTIAL_COMPUTING=0
ENABLE_CLOUD_ARMOR=0

# Deployment outputs (set after deploy_agent.py)
AGENT_ENGINE_ID=
AGENT_IDENTITY=
